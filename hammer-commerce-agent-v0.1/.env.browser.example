# 前端构建时填写 Browser Agent 服务地址
VITE_BROWSER_AGENT_URL=https://browser-agent.example.com

# Browser Agent 服务
BROWSER_AGENT_PORT=8787
BROWSER_ALLOWED_ORIGIN=https://commerce-agent.example.com
BROWSER_PUBLIC_BASE_URL=https://browser-agent.example.com
BROWSER_RATE_LIMIT=10

# 基础版默认开启公开抓取测试商城，仅用于验证 Browser Tool 链路
BROWSER_ENABLE_DEMO=true

# 仅在公司代理使用自签名证书时启用；公共部署保持 false
BROWSER_IGNORE_HTTPS_ERRORS=false

# 接入真实公开来源时由服务端配置固定 URL 与选择器；客户端不能提交任意 URL
# BROWSER_SOURCE_CONFIG_JSON=[{"id":"platform-a","name":"平台A","searchUrl":"https://example.com/search?q={query}","itemSelector":".product","titleSelector":".title","linkSelector":".title","priceSelector":".price","descriptionSelector":".description","imageSelector":"img","salesSelector":".sales","ratingSelector":".rating"}]
